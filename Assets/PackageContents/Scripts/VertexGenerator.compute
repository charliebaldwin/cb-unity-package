#pragma kernel GenerateGrid
#pragma kernel ComputeMesh

#include "Packages/jp.keijiro.noiseshader/Shader/SimplexNoise3D.hlsl"

RWTexture3D<float4> Voxels;
int Size;
uint3 Size3D;
float Scale;
float Threshold;
float3 TranslateNoise;


[numthreads(16,1,16)]
void GenerateGrid (uint3 id : SV_DispatchThreadID)
{
    for (int y=0; y<Size3D.y; y++) {
        float3 pos = float3(id.x, y, id.z);
        float n = SimplexNoise(pos * Scale + TranslateNoise);
        float yRamp = 1.0 - (float(y) / Size3D.y);
        n += pow(yRamp, 2.0);
        n *= pow(yRamp, 0.5);
        n = clamp(n, 0.0, 1.0);
        Voxels[pos] = float4(n, n, n, 1.0);
    }


    // Result[id.xy] = float4(id.x & id.y, (id.x & 15)/15.0, (id.y & 15)/15.0, 0.0);
}   





