RWStructuredBuffer<float3> Vertices;
RWStructuredBuffer<float3> Normals;
RWStructuredBuffer<float4> Colors;
RWStructuredBuffer<float2> TexCoords;

[numthreads(16,1,16)]
void ComputeMesh (uint3 id : SV_DispatchThreadID)
{
    
    for (int y=0; y<Size3D.y; y++) {
        float3 pos = float3(id.x % Size3D.x, y, id.z % Size3D.z);
        int index = 24*(pos.y + Size3D.y * pos.x + Size3D.y * Size3D.x * pos.z);

        float voxel = Voxels[pos].x;

        

        if (voxel >= Threshold) {

            float vox_nx = 0.0;
            float vox_px = 0.0;
            float vox_ny = 0.0;
            float vox_py = 0.0;
            float vox_nz = 0.0;
            float vox_pz = 0.0;

            if (pos.x > 0) {
                vox_nx = Voxels[pos + float3(-1.0, 0.0, 0.0)].x;
            }
            if (pos.x < Size3D.x - 1){
                vox_px = Voxels[pos + float3(1.0, 0.0, 0.0)].x;
            }
            if (pos.y > 0) {
                vox_ny = Voxels[pos + float3(0.0, -1.0, 0.0)].x;
            }
            if (pos.y < Size3D.y - 1){
                vox_py = Voxels[pos + float3(0.0, 1.0, 0.0)].x;
            }
            if (pos.z > 0) {
                vox_nz = Voxels[pos + float3(0.0, 0.0, -1.0)].x;
            }
            if (pos.z < Size3D.z - 1){
                vox_pz = Voxels[pos + float3(0.0, 0.0, 1.0)].x;
            }


            if (vox_nx < Threshold) {
                for(int i=0; i<4; i++) {
                    Vertices[index + i] = faceVertsNX[i] + pos;
                    Normals[index + i] = faceNormNX;
                    Colors[index + i] = float4(0.0,1.0,0.0,1.0);
                    TexCoords[index + i] = faceTexNX[3-i];
                }
            }
            if (vox_px < Threshold) {
                for(int i=0; i<4; i++) {
                    Vertices[index + i + 4] = faceVertsPX[i] + pos;
                    Normals[index + i + 4] = faceNormPX;
                    Colors[index + i + 4] = float4(0.0,1.0,0.0,1.0);
                    TexCoords[index + i + 4] = faceTexPX[3-i];
                }
            }
            if (vox_ny < Threshold) {
                for(int i=0; i<4; i++) {
                    Vertices[index + i + 8] = faceVertsNY[i] + pos;
                    Normals[index + i + 8] = faceNormNY;
                    Colors[index + i + 8] = float4(0.0,1.0,0.0,1.0);
                    TexCoords[index + i + 8] = faceTexNY[3-i];
                }
            }
            if (vox_py < Threshold) {
                for(int i=0; i<4; i++) {
                    Vertices[index + i + 12] = faceVertsPY[i] + pos;
                    Normals[index + i + 12] = faceNormPY;
                    Colors[index + i + 12] = float4(0.0,1.0,0.0,1.0);
                    TexCoords[index + i + 12] = faceTexPY[3-i];
                }
            }
            if (vox_nz < Threshold) {
                for(int i=0; i<4; i++) {
                    Vertices[index + i + 16] = faceVertsNZ[i] + pos;
                    Normals[index + i + 16] = faceNormNZ;
                    Colors[index + i + 16] = float4(0.0,1.0,0.0,1.0);
                    TexCoords[index + i + 16] = faceTexNZ[3-i];
                }
            }
            if (vox_pz < Threshold) {
                for(int i=0; i<4; i++) {
                    Vertices[index + i + 20] = faceVertsPZ[i] + pos;
                    Normals[index + i + 20] = faceNormPZ;
                    Colors[index + i + 20] = float4(0.0,1.0,0.0,1.0);
                    TexCoords[index + i + 20] = faceTexPZ[3-i];
                }
            }



            //for (int v = 0; v < 24; v++) {
            //    float3 vert = vertArray[v];
            //    Vertices[v + index] = float3(vert.x + pos.x, vert.y + pos.y, vert.z + pos.z);
            //    Normals[v + index] = normArray[v];
            //    //Colors[v + index] = float4(pos.x / Size3D.x, pos.y / Size3D.y, pos.z / Size3D.z, 1.0);
            //    Colors[v + index] = float4(0.0,1.0,0.0,1.0);

            //}


        }
    }

    //else if (voxel == 0.0) {
    //    for (int v = 0; v < 24; v++) {
    //        Vertices[v + index] = float3(0.0,0.0,0.0);
    //        Normals[v + index] = float3(0.0,0.0,0.0);
    //        Colors[v + index] = float4(0.0,0.0,0.0,0.0);
    //    }
    //}

    

   // for (int t=0; t<36; t++) {
   //     Triangles[t] = triArray[t];
   // }

    
