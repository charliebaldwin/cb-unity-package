    //if (v == 1) {
    //    Connections adj;
    //    adj.nx=1;
    //    adj.px=1;
    //    adj.ny=1;
    //    adj.py=1;
    //    adj.nz=1;
    //    adj.pz=1;

    //    if (id.x > 0) {
    //       adj.nx = 1-Voxels[id.xyz + uint3(-1, 0, 0)]; 
    //    }
    //    if (id.x < Size-1) {
    //       adj.px = 1-Voxels[id.xyz + uint3( 1, 0, 0)]; 
    //    }
    //    if (id.y > 0) {
    //       adj.ny = 1-Voxels[id.xyz + uint3( 0,-1, 0)]; 
    //    }
    //    if (id.y < Size-1) {
    //       adj.py = 1-Voxels[id.xyz + uint3( 0, 1, 0)]; 
    //    }
    //    if (id.z > 0) {
    //       adj.nz = 1-Voxels[id.xyz + uint3( 0, 0,-1)]; 
    //    }
    //    if (id.z < Size-1) {
    //       adj.pz = 1-Voxels[id.xyz + uint3( 0, 0, 1)]; 
    //    }

    //}
}