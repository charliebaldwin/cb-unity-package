#pragma kernel GenerateGrid
#pragma kernel ComputeMesh
#pragma kernel DeleteVoxel

#include "Packages/jp.keijiro.noiseshader/Shader/SimplexNoise3D.hlsl"

//RWTexture3D<float4> VoxelTex;
RWStructuredBuffer<int> Voxels;
uint3 Size;
float Scale;
float Threshold;
float3 TranslateNoise;

int ComputeIndex(uint3 pos, uint3 size) {
    //return (pos.x % size.x) + size.x * (pos.y % size.y) + size.x * size.y * (pos.z % size.z);
    return (pos.x) + size.x * (pos.y) + size.x * size.y * (pos.z);
}


[numthreads(16,4,16)]
void GenerateGrid (uint3 id : SV_DispatchThreadID)
{
    for (uint y=0; y<Size.y; y++) {
        uint3 pos = uint3(id.x % Size.x, y, id.z % Size.z);
        float n = 3*SimplexNoise(pos * Scale + TranslateNoise);
        float yRamp = 1.0 - (float(y) / Size.y);
        n += 5*pow(yRamp, 3.0);
        n *= pow(yRamp, 0.5);
        //n = clamp(n, 0.0, 1.0);
        

        int index = ComputeIndex(pos, Size);
        Voxels[index] = max(int(floor(n * Threshold)), 0);
        //Voxels[index] = 1;
    }

}   





